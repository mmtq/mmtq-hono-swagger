{
  "name": "@mmtq/hono-swagger",
  "version": "1.0.0-beta.0",
  "description": "Build-time OpenAPI generator for Hono + Zod",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "hono-swagger": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./helpers": {
      "import": "./dist/helpers/index.js",
      "require": "./dist/helpers/index.js",
      "types": "./dist/helpers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.helpers.json",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "openapi-types": "^12.1.3",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.3",
    "ts-morph": "^22.0.0",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.9",
    "@hono/node-server": "^1.11.4",
    "@hono/zod-validator": "^0.2.2",
    "hono": "^4.4.12",
    "vitest": "^2.0.1"
  },
  "peerDependencies": {
    "hono": "^4.x",
    "zod": "^3.x"
  }
}